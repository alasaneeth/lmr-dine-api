# ─────────────────────────────────────────────
#  RestoMS – Environment Configuration
#  Copy this to .env and fill in real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── Server ──────────────────────────────────
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# ── Database (MySQL) ─────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=restoms_db
DB_USER=restoms_user
DB_PASSWORD=your_strong_password_here
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ── JWT ──────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_256bit_random_string
JWT_REFRESH_SECRET=change_me_refresh_secret_256bit_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Bcrypt ───────────────────────────────────
BCRYPT_ROUNDS=12

# ── CORS ─────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Rate Limiting ────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── File Upload ──────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ── Logging ──────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs

# ── MFA ──────────────────────────────────────
MFA_ISSUER=RestoMS

# ── Frontend URL ─────────────────────────────
FRONTEND_URL=http://localhost:5173
