# ─────────────────────────────────────────────────────────
#  RMS Backend – Environment Variables
#  Copy to .env and fill in real values. NEVER commit .env.
# ─────────────────────────────────────────────────────────

# Server
NODE_ENV=production
PORT=5000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rms_db
DB_USER=rms_user
DB_PASS=change_me_strong_password
DB_ROOT_PASS=change_me_root_password
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# JWT  –  generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_64+_CHAR_RANDOM_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64+_CHAR_RANDOM_HEX
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS – comma-separated list of allowed origins
# In production with nginx on same origin, this can just be your domain.
CORS_ORIGINS=https://your-production-domain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=change_me_redis_password

# Bcrypt
BCRYPT_ROUNDS=12

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Sentry (optional – leave blank to disable)
SENTRY_DSN=
