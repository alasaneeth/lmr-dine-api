# ─────────────────────────────────────────────────────────
#  RMS Backend – Environment Variables
# ─────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rms_db
DB_USER=root
DB_PASS=
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# JWT
JWT_ACCESS_SECRET=your-very-long-access-secret-min-64-chars-change-in-production
JWT_REFRESH_SECRET=your-very-long-refresh-secret-min-64-chars-change-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Redis (for Bull queues – optional in dev, required in prod)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

# Bcrypt
BCRYPT_ROUNDS=12

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Sentry (optional)
SENTRY_DSN=
